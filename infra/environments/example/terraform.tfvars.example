do_token             = "replace-me"
do_region            = "lon1"
name                 = "argusai-home"
droplet_size         = "s-1vcpu-1gb"
image                = "ubuntu-24-04-x64"
ssh_key_fingerprint  = "your-digitalocean-ssh-key-fingerprint"
ssh_cidr             = "x.x.x.x/32"
app_port             = 8000
app_dir              = "/opt/argusai"

tags = {
  project     = "argusai"
  environment = "example"
}
